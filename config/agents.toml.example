# ---------------------------------------------------------------------------
# Agents
# ---------------------------------------------------------------------------
# Each agent authenticates with a bearer token and declares which MCP servers
# it may access.  Per-agent rule overrides live in rules-agents.toml.
#
# token       — bearer token the agent sends; use env: references
# mcp_servers — list of [mcp_servers.*] names this agent can see
# log_only    — if true, enforcement is bypassed for downstream MCP calls
#               (native tool calls are always enforced regardless of this flag)

[agents.default]
token       = "env:DEFAULT_AGENT_TOKEN"
mcp_servers = ["homeassistant"]
log_only    = false

# [agents.readonly_bot]
# token       = "env:READONLY_BOT_TOKEN"
# mcp_servers = ["homeassistant"]
# log_only    = false
