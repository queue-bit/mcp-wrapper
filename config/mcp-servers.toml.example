# ---------------------------------------------------------------------------
# Downstream MCP servers
# ---------------------------------------------------------------------------
# Add one [mcp_servers.<name>] block per MCP server.
# The credential value uses any secret reference prefix (see wrapper.toml.example).
#
# Rules for each server live in rules-defaults.toml under [<server-name>].
#
# response_fields / max_response_chars — reduce response size to protect the
#   calling agent's context window.  To generate good values, make a sample
#   tool call, capture the raw response, then ask Claude (or another LLM):
#
#   "Given this MCP tool response, suggest response_fields (dot-path strings
#    to the most useful fields) and a max_response_chars limit appropriate for
#    a 4k-token context window.  Format the answer as TOML config lines."

[mcp_servers.homeassistant]
url        = "http://localhost:8123/api/mcp"
credential = "env:HA_TOKEN"
# max_response_chars = 4000   # truncate large responses to keep agent context small

# [mcp_servers.gmail]
# url                = "https://gmail-mcp.example.com/mcp"
# credential         = "vault:mcp-wrapper/gmail#token"
# response_fields    = ["content"]          # drop isError and other envelope fields
# max_response_chars = 8000                 # email bodies can be large
